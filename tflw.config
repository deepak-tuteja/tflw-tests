# testFlow-tests v2 config: a single Dockerized NestJS+Postgres service (apiV2), everything
# under one host port with a real `/v1` prefix baked into the env's base URL. The old
# `api`/`auth` named-service split is gone — both auth transports now live in the same app.
# `admin` showcases bearer auth; `shopper` showcases cookie auth via tflw's automatic cookie jar
# (SPEC §3.3, P#33, shipped in tflw 0.1.0's M5 gap-fix pass) — no manual `capture header
# "set-cookie"`/`header "Cookie" is …` needed anymore. `session-login-full`'s dual Set-Cookie
# (`session` + `session_refresh`) is still exercised by a dedicated non-session test in
# sessions.tflw (it asserts on the raw header's own attributes, unrelated to jar consumption) —
# see TFLW-GAPS.md #1 for the gap this fixed and tests/cookie-jar.tflw for the executable proof.

# `defaults: timeout wait 5s` (PLAN M1.5): keeps tests/.demo-fail/wait-timeout.tflw's intentional
# timeout fast (~5s) instead of the runtime's 30s default.
defaults
  timeout wait 5s

env local default
  api "http://localhost:4001/v1"
  # Unversioned root (M3): Swagger/OpenAPI mounts outside the `/v1` prefix, and this base also
  # proves the prefix is genuinely enforced (a versioned-only route 404s when hit unversioned).
  api root "http://localhost:4001"

session admin
  api POST /auth/login body { email: env(ADMIN_EMAIL), password: env(ADMIN_PW) }
  expect status equals 200
  capture body.accessToken as token
  header "Authorization" is "Bearer {token}"

session shopper
  api POST /auth/session-login body { email: env(USER_A_EMAIL), password: env(USER_A_PW) }
  expect status equals 200
  # cookies auto-tracked from Set-Cookie by the jar — no capture/header needed

require env ADMIN_EMAIL, ADMIN_PW, USER_A_EMAIL, USER_A_PW, USER_B_EMAIL, USER_B_PW
