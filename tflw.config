# testFlow-tests v2 config: a single Dockerized NestJS+Postgres service (apiV2), everything
# under one host port with a real `/v1` prefix baked into the env's base URL. The old
# `api`/`auth` named-service split is gone — both auth transports now live in the same app.
# `admin` showcases bearer auth; `shopper` showcases cookie auth via tflw's automatic cookie jar
# (SPEC §3.3, P#33, shipped in tflw 0.1.0's M5 gap-fix pass) — no manual `capture header
# "set-cookie"`/`header "Cookie" is …` needed anymore. `session-login-full`'s dual Set-Cookie
# (`session` + `session_refresh`) is still exercised by a dedicated non-session test in
# sessions.tflw (it asserts on the raw header's own attributes, unrelated to jar consumption) —
# see TFLW-GAPS.md #1 for the gap this fixed and tests/cookie-jar.tflw for the executable proof.

# `defaults: timeout wait 5s` (PLAN M1.5): keeps tests/.demo-fail/wait-timeout.tflw's intentional
# timeout fast (~5s) instead of the runtime's 30s default.
defaults
  timeout wait 5s

env local default
  api "http://localhost:4001/v1"
  # Unversioned root (M3): Swagger/OpenAPI mounts outside the `/v1` prefix, and this base also
  # proves the prefix is genuinely enforced (a versioned-only route 404s when hit unversioned).
  api root "http://localhost:4001"
  # M23 (enterprise arc cluster 2 consumption, testFlow PLAN.md decision 101a): every test in this
  # suite only ever talks to `localhost`, so allowlisting it here has zero blast radius on the
  # other ~30 files — it's the positive-path proof that a real allowlist doesn't false-positive-
  # block normal traffic. The negative case (a host genuinely blocked) needs a *different*
  # allowlist that excludes localhost — see `env allowHostsBlocked` below, its own dedicated env
  # for the same blast-radius reason `mtlsSidecar` is dedicated.
  allow hosts "localhost"

# M22 (enterprise arc cluster 1): the nginx TLS sidecar's mTLS-requiring listener (8444, proxying
# to the same api:4001 backend — see ../nginx/). Deliberately its own `env`, not folded into
# `local` above: setting `cert`/`key` routes *every* request in the active env through tflw's
# undici mTLS dispatcher instead of the plain global fetch (testFlow PLAN.md decision 99b) — fine
# for this one dedicated file, but pointless blast radius against the other ~30 files that only
# ever need the plain :4001 backend. Run with `tflw run --env mtlsSidecar` (or `npm run
# test:mtls`), not part of the default `npm test` run. `insecure true` because the sidecar's
# server cert is signed by a throwaway CA generated fresh per container start (never a stable
# trust root worth pointing NODE_EXTRA_CA_CERTS at) — the client certificate below is the actual
# thing under test, not server-cert trust.
env mtlsSidecar
  api "https://localhost:8444/v1"
  insecure true
  # Relative to the *consuming* .tflw file's own directory, not tflw.config's — same file-relative
  # convention as `import`/`use`/`with each from` (runtime's `baseDir` is per-file, dirname(file)
  # in packages/cli/src/cli.ts). Every file that opts into this env lives directly under `tests/`,
  # one level below the project root these certs actually live in.
  cert "../nginx/certs/client.pem"
  key "../nginx/certs/client.key"

# M23 (enterprise arc cluster 2 consumption, testFlow PLAN.md decision 101d): declarative field
# redaction against the new PII-rich `/profile/export` fixture (PLAN_ENTERPRISE.md decision 11,
# apiV2/src/profile-export/). Its own dedicated env for the same reason `mtlsSidecar` is dedicated
# — `redact` has no CLI override (unlike `evidence`, which tests/safety-redaction.tflw exercises
# via `--evidence` at run time instead, no env needed), so it would otherwise mask matching fields
# in every other file's report too if declared under `local`. `body.email` masks the top-level
# field the endpoint returns; `body.address.*` masks every key *under* `address` (street/city/
# postalCode) — a trailing wildcard, complementing tflw's own `body.*.address` (leading-wildcard,
# over an array) unit coverage in packages/runtime/test/field-redaction.test.ts.
env safetyRedaction
  api "http://localhost:4001/v1"
  redact body.email, body.address.*

# M23: the negative case for `allow hosts` — a real host genuinely gets blocked, not just "never
# happens to matter because everything already points at localhost" (env local's own allowlist
# above). Same api base as local/safetyRedaction, but the allowlist deliberately excludes
# localhost.
env allowHostsBlocked
  api "http://localhost:4001/v1"
  allow hosts "example.com"

session admin
  api POST /auth/login body { email: env(ADMIN_EMAIL), password: env(ADMIN_PW) }
  expect status equals 200
  capture body.accessToken as token
  header "Authorization" is "Bearer {token}"

session shopper
  api POST /auth/session-login body { email: env(USER_A_EMAIL), password: env(USER_A_PW) }
  expect status equals 200
  # cookies auto-tracked from Set-Cookie by the jar — no capture/header needed

# M22 (enterprise arc cluster 1): the `oauth2` session sugar (testFlow PLAN.md decision 99c),
# against apiV2's new `/oauth/token` client-credentials endpoint (PLAN_ENTERPRISE.md decision 11).
# Two clients, mirroring the two configured server-side (apiV2/src/oauth/oauth.service.ts):
# `oauthLong` (normal TTL, plain reuse) and `oauthShort` (~5s TTL, proactively re-fetched ahead of
# expiry — tests/session-refresh-and-oauth2.tflw exercises the difference). The token endpoint is
# hardcoded to the real api's own base port, same convention as `env local`'s own hardcoded `api`
# value above — it's independent of whichever env is active, since a client-credentials grant
# isn't itself a per-env concept.
session oauthLong oauth2
  token url "http://localhost:4001/v1/oauth/token"
  client id env(OAUTH_CLIENT_ID)
  client secret env(OAUTH_CLIENT_SECRET)
  scope "orders.read orders.write"

session oauthShort oauth2
  token url "http://localhost:4001/v1/oauth/token"
  client id env(OAUTH_SHORT_CLIENT_ID)
  client secret env(OAUTH_SHORT_CLIENT_SECRET)

require env ADMIN_EMAIL, ADMIN_PW, USER_A_EMAIL, USER_A_PW, USER_B_EMAIL, USER_B_PW, OAUTH_CLIENT_ID, OAUTH_CLIENT_SECRET, OAUTH_SHORT_CLIENT_ID, OAUTH_SHORT_CLIENT_SECRET
