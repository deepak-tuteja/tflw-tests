# testFlow-tests config: two named services (core default, auth named) so tests can exercise
# tflw's multi-service support and cross-service capture-chaining (login on `auth`, act on
# `core` with the captured token). Two sessions showcase both auth transports tflw supports:
# `admin` (bearer) and `shopper` (cookie-based, same pattern proven against restful-booker).

env local default
  api "http://localhost:4001"
  api auth "http://localhost:4002"

session admin
  api auth POST /auth/login body { email: env(ADMIN_EMAIL), password: env(ADMIN_PW) }
  expect status equals 200
  capture body.token as token
  header "Authorization" is "Bearer {token}"

session shopper
  api auth POST /auth/session-login body { email: env(USER_EMAIL), password: env(USER_PW) }
  expect status equals 200
  capture body.sessionId as sid
  header "Cookie" is "tf_sid={sid}"

require env ADMIN_EMAIL, ADMIN_PW, USER_EMAIL, USER_PW
