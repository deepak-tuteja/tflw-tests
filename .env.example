# Copy to .env (gitignored) before `node cli.mjs start`.

# Postgres (used by docker-compose and apiV2's TypeORM connection)
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=testflow_tests

# JWT (M1 — access/refresh auth). Two secrets, four TTLs: ACCESS_SECRET signs both the bearer
# access token and the cookie session token (both "access-class"); REFRESH_SECRET signs both the
# bearer refresh token and the cookie session_refresh token (both "refresh-class").
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=5s
JWT_REFRESH_TTL=1h
JWT_SESSION_TTL=1h
JWT_SESSION_REFRESH_TTL=2h

# Seeded identities (admin + two distinct users, for authz cross-user tests)
ADMIN_EMAIL=admin@example.com
ADMIN_PW=admin-pw-123
USER_A_EMAIL=alice@example.com
USER_A_PW=alice-pw-123
USER_B_EMAIL=bob@example.com
USER_B_PW=bob-pw-123

# OAuth2 client-credentials grant (M22, enterprise arc cluster 1 — dogfoods tflw's `oauth2`
# session sugar). Two clients: a normal-TTL one and a short-TTL one, so tests can exercise both
# plain token reuse and tflw's proactive re-fetch-before-expiry path.
OAUTH_CLIENT_ID=tflw-oauth-client
OAUTH_CLIENT_SECRET=tflw-oauth-secret
OAUTH_ACCESS_TTL=1h
OAUTH_SHORT_CLIENT_ID=tflw-oauth-short-client
OAUTH_SHORT_CLIENT_SECRET=tflw-oauth-short-secret
OAUTH_SHORT_ACCESS_TTL=5s
