# batch.tflw — POST /products/batch validates each item independently (not all-or-nothing) and
# returns 207 Multi-Status with a per-item result array. `with each` (SPEC §4.3) drives one row
# per case; since a row supplies one item, not an accumulator across rows, every request pairs
# the row's item with a fixed, always-valid filler item as the batch's second element, so every
# case is a genuine 2-item batch with a real partial/full-success shape to assert on.
#
# Ported to v2 (plan_v2.md Part E, M12): broadened beyond v1's single "bad price" case with two
# more independent per-item failure reasons — unknown category and duplicate name within the
# same batch — each verified below with a dedicated reason-level assertion (the duplicate-name
# case inherently needs two items sharing a name in one request, not a row+filler pair, so it
# gets its own standalone test rather than a table row).

before
  api GET /categories
  expect status equals 200
  capture body[0].id as categoryId

  api POST /auth/login body { email: env(ADMIN_EMAIL), password: env(ADMIN_PW) }
  expect status equals 200
  capture body.accessToken as adminToken

@batch @crud @catalogOps
with each
  | label        | price | shouldSucceed |
  | "Batch Good" | 12    | true          |
  | "Batch Bad"  | -5    | false         |
test "batch-creates {label} alongside a fixed always-valid filler item"
  api POST /products/batch body {
      items: [
        { name: unique("{label}"), price: {price}, stock: 5, categoryId: {categoryId} },
        { name: unique("Filler Item"), price: 1, stock: 1, categoryId: {categoryId} }
      ]
    }
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 207
  expect body.results[0].ok equals {shouldSucceed}
  expect body.results[1].ok equals true
  expect body.succeeded is greater than 0

@batch @crud @catalogOps
test "batch reports the invalid-price reason on the failing item"
  api POST /products/batch body {
      items: [
        { name: unique("Bad Price Widget"), price: -5, stock: 5, categoryId: {categoryId} },
        { name: unique("Filler Item"), price: 1, stock: 1, categoryId: {categoryId} }
      ]
    }
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 207
  expect body.results[0].ok equals false
  expect body.results[0].reason equals "invalid price"
  expect body.succeeded equals 1
  expect body.failed equals 1

@batch @crud @catalogOps
test "batch reports the unknown-category reason on the failing item"
  let badCategoryId = random uuid
  api POST /products/batch body {
      items: [
        { name: unique("Bad Category Widget"), price: 10, stock: 5, categoryId: {badCategoryId} },
        { name: unique("Filler Item"), price: 1, stock: 1, categoryId: {categoryId} }
      ]
    }
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 207
  expect body.results[0].ok equals false
  expect body.results[0].reason equals "unknown category"
  expect body.succeeded equals 1
  expect body.failed equals 1

@batch @crud @catalogOps
test "batch reports the duplicate-name reason on the second occurrence"
  let dupName = unique("Repeated Widget")
  api POST /products/batch body {
      items: [
        { name: {dupName}, price: 10, stock: 5, categoryId: {categoryId} },
        { name: {dupName}, price: 12, stock: 3, categoryId: {categoryId} }
      ]
    }
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 207
  expect body.results[0].ok equals true
  expect body.results[1].ok equals false
  expect body.results[1].reason equals "duplicate name in batch"
  expect body.succeeded equals 1
  expect body.failed equals 1

@batch @crud @catalogOps
test "a non-admin bearer cannot batch-create products"
  api POST /auth/login body { email: env(USER_A_EMAIL), password: env(USER_A_PW) }
  expect status equals 200
  capture body.accessToken as token

  api POST /products/batch body { items: [ { name: unique("Sneaky Widget"), price: 1, stock: 1, categoryId: {categoryId} } ] }
    header "Authorization" is "Bearer {token}"
  expect status equals 403
