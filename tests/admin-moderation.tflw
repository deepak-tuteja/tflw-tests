# admin-moderation.tflw — M13 kitchen-sink (plan_v2.md Part F decision 5): the admin/moderation
# side of the shop, combining RBAC + cross-user authz, hooks, `retry` against a real flaky
# dependency, `with each` driving several admin actions, and a mixed-pass/fail batch import —
# the features an admin-facing test suite actually reaches for together, in one realistic file.

before file
  api GET /health
  expect status equals 200

before
  api GET /categories
  expect status equals 200
  capture body[0].id as categoryId

  api POST /auth/login body { email: env(ADMIN_EMAIL), password: env(ADMIN_PW) }
  expect status equals 200
  capture body.accessToken as adminToken

  api POST /auth/login body { email: env(USER_A_EMAIL), password: env(USER_A_PW) }
  expect status equals 200
  capture body.accessToken as userAToken

@moderation @retry @adminOps
test "an admin retries a flaky upstream dependency check before starting moderation work" retry 2
  let key = random string 8
  api POST /flaky-widget body { key: {key} }
  expect status equals 201

@moderation @datatables @adminOps
with each
  | label            | price | stock |
  | "Mod Catalog A"   | 9     | 20    |
  | "Mod Catalog B"   | 19    | 5     |
  | "Mod Catalog C"   | 29    | 0     |
test "admin adds {label} to the catalog at price {price}, stock {stock}"
  api POST /products body { name: unique("{label}"), price: {price}, stock: {stock}, categoryId: {categoryId} }
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 201
  expect body.stock equals {stock}

@moderation @authz @adminOps
test "the same catalog-moderation action is forbidden for a non-admin identity"
  api POST /products body { name: unique("Should Be Forbidden"), price: 9, stock: 1, categoryId: {categoryId} }
    header "Authorization" is "Bearer {userAToken}"
  expect status equals 403

  api GET /orders/all
    header "Authorization" is "Bearer {userAToken}"
  expect status equals 403

@moderation @batch @adminOps
test "a bulk catalog import batch reports mixed success without failing the whole request"
  let goodName = unique("Bulk Import Good")
  let badCategoryId = random uuid
  api POST /products/batch body {
      items: [
        { name: {goodName}, price: 15, stock: 10, categoryId: {categoryId} },
        { name: "Bulk Import Bad Price", price: -1, stock: 10, categoryId: {categoryId} },
        { name: "Bulk Import Bad Category", price: 15, stock: 10, categoryId: {badCategoryId} }
      ]
    }
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 207
  expect body.succeeded equals 1
  expect body.failed equals 2
  expect body.results[0].ok equals true
  expect any body.results matches subset { ok: false, reason: "invalid price" }
  expect any body.results matches subset { ok: false, reason: "unknown category" }
