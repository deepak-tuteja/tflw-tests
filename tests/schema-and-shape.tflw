# schema-and-shape.tflw — M5 gap-provoking scenarios (plan_v2.md Part B): partial-object/subtree
# matching and schema/contract validation against `/openapi.json`. Both are recognized-but-
# deferred in tflw's own SPEC §16 parking lot (P#14, P#3) — this file gives each a concrete,
# working scenario (the escape-hatch route that keeps the suite green) plus an "ideal syntax"
# comment showing what we wish we could write instead. See TFLW-GAPS.md for the ranked writeup.

use "./helpers/schema-check.ts"

before
  api GET /categories
  expect status equals 200
  capture body[0].id as categoryId

@gaps @shape
test "asserting a full RFC7807 error shape today needs one statement per field" as admin
  api POST /products body { name: "", price: -5, stock: 1, categoryId: "not-a-uuid" }
  expect status equals 422
  # No way to assert "this object contains at least these key/value pairs" in a single statement
  # (SPEC §16 P#14, "partial-object JSON matching") — each field needs its own `expect`, and
  # there's no way to ignore the (legitimately variable) `errors` array while still asserting the
  # rest of the shape in one go.
  expect body.type equals "about:blank"
  expect body.title equals "Unprocessable Entity"
  expect body.status equals 422
  # Ideal (doesn't exist today):
  #   expect body matches subset { type: "about:blank", title: "Unprocessable Entity", status: 422 }

@gaps @schema
test "validating a response against its own documented OpenAPI schema needs a JS helper" as admin
  api POST /products body { name: unique("Schema-checked Widget"), price: 12.5, stock: 3, categoryId: {categoryId} }
  expect status equals 201
  capture body as product

  # Throws (failing the test) if `product` doesn't match ProductResponseDto's schema in
  # /openapi.json — the call itself *is* the assertion, since there's no declarative primitive
  # to point an `expect` at an externally-documented schema (SPEC §16 P#3, "OpenAPI/contract").
  let result = assert matches schema("ProductResponseDto", product)

  # Ideal (doesn't exist today), referencing the endpoint's own documented response shape with no
  # hardcoded schema name or JS helper:
  #   expect body matches schema from "/openapi.json"
