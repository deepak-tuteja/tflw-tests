# quantifiers.tflw — `any`/`all` over the array-returning /orders/{id}/items endpoint.
#
# Redesigned for v2 (plan_v2.md Part E, M12): v1's asserted shape (`body.orders.total`/`.qty`)
# doesn't exist in v2 at all — `GET /orders` returns a flat `Order[]` with no top-level
# `total`/`qty`; those concepts now live inside each order's nested `items[]`. Quantifying
# directly over `GET /orders/{id}/items` (a genuinely flat array, same endpoint order-items.tflw
# exercises) keeps this expressible with today's one-array-level quantifier design
# (`evaluateQuantified`, packages/runtime/src/interpreter.ts:879) — see
# tests/.gaps/nested-array-quantifier.tflw for what happens when a path instead tries to
# quantify into a *second*, nested array (`GET /orders/all`'s embedded `items[]`), a real limit
# this redesign surfaced and is now tracked as TFLW-GAPS.md gap #11.

before
  api GET /categories
  expect status equals 200
  capture body[0].id as categoryId

@crud @quantifiers
test "quantifiers over one order's items" as admin
  api POST /products body { name: unique("Quant Widget A"), price: 5, stock: 10, categoryId: {categoryId} }
  expect status equals 201
  capture body.id as productIdA

  api POST /products body { name: unique("Quant Widget B"), price: 5, stock: 10, categoryId: {categoryId} }
  expect status equals 201
  capture body.id as productIdB

  api POST /orders body { items: [ { productId: {productIdA}, quantity: 3 }, { productId: {productIdB}, quantity: 1 } ] }
  expect status equals 201
  capture body.id as orderId

  api GET /orders/{orderId}/items
  expect status equals 200
  expect all body.quantity is greater than 0
  expect any body.quantity equals 3
  expect any body matches subset { productId: "{productIdA}", quantity: 3 }
