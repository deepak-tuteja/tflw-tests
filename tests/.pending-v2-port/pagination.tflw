# pagination.tflw — GET /products?page=N&pageSize=M is optional (absent -> today's exact
# unpaginated shape, so the untouched frontend is unaffected). No native page-walk primitive
# exists in the DSL (no loops by design, SPEC §7.5) — the JS escape hatch does the page-walking;
# the plain DSL can only ever assert a single page's shape directly. Logged as
# TFLW-FEATURE-GAPS.md #1. Both tests are unauthenticated: GET /products needs no bearer/session.

use "./helpers/paginate.ts"

before
  let ns = random string 12

@pagination @crud
test "a single page reports its own shape"
  api GET /products?page=1&pageSize=2
    header "X-Test-NS" is "{ns}"
  expect status equals 200
  expect body.page equals 1
  expect body.pageSize equals 2
  expect body.total equals 3
  expect body.totalPages equals 2

@pagination @crud
test "walking every page (via the JS escape hatch) sees every product exactly once"
  let aggregatedCount = walk all pages(ns, 2)

  api GET /products
    header "X-Test-NS" is "{ns}"
  expect status equals 200
  expect body.total equals {aggregatedCount}
