# generators.tflw — the unique/random generator family: unique email/unique(prefix) for
# collision-free registration data, random decimal/random of for varied product fields.

before
  let ns = random string 12

@auth @generators
test "registers a user with a generated unique email"
  api auth POST /auth/register body { email: unique email, password: "GenPass123", name: unique("Gen User") }
  expect status equals 201
  expect body.user.role equals "user"

@auth @generators
test "registering the same email twice is rejected"
  let dupEmail = unique email

  api auth POST /auth/register body { email: {dupEmail}, password: "GenPass123", name: "Dup User" }
  expect status equals 201

  api auth POST /auth/register body { email: {dupEmail}, password: "GenPass123", name: "Dup User Again" }
  expect status equals 400

@crud @generators
test "creates a product with random generated fields" as admin
  let productName = unique("Random Widget")
  let price = random decimal 5 to 50
  api POST /products body { name: {productName}, price: {price}, category: random of "electronics", "stationery", "kitchen" }
    header "X-Test-NS" is "{ns}"
  expect status equals 201
  expect body.name equals {productName}
