# order-workflow.tflw — a multi-stage async order lifecycle (pending -> processing -> shipped ->
# delivered), each transition observed via its own `wait until api` poll: stresses `wait until
# api` and capture-chaining across more than one stage transition (PLAN M1.5). Extracted from
# retry-and-flake.tflw, rewritten for the new status vocabulary ("ready" no longer exists).
#
# No `X-Test-NS` namespacing here (unlike most other files): `wait until api` steps cannot carry
# a per-step header — only plain `api` steps can (checked against the parser: `parseWaitUntilApi`
# never calls `parseApiHeaders`, unlike `parseApiStep`) — logged in TFLW-FEATURE-GAPS.md. Safe to
# skip anyway: this test only ever looks up its own order by its (globally unique) id, never a
# filtered/unfiltered list, so `default`-bucket contamination from other parallel files can't
# affect it — namespacing exists to protect list-based/keyed-collision assertions, neither of
# which this test makes.

@workflow
test "an order progresses through every stage of its lifecycle" as admin
  api POST /products body { name: unique("Workflow Widget"), price: 10, category: "misc" }
  expect status equals 201
  capture body.id as productId

  api POST /orders body { productId: {productId}, qty: 1 }
  expect status equals 201
  expect body.status equals "pending"
  capture body.id as orderId

  wait until api GET /orders/{orderId}
    expect body.status equals "processing"

  wait until api GET /orders/{orderId}
    expect body.status equals "shipped"

  wait until api GET /orders/{orderId}
    expect body.status equals "delivered"
