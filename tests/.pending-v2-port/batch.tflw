# batch.tflw — POST /products/batch validates each item independently (not all-or-nothing) and
# returns 207 Multi-Status with a per-item result array. `with each` (SPEC §4.3) drives one row
# per case; since a row supplies one item, not an accumulator across rows, every request pairs
# the row's item with a fixed, always-valid filler item as the batch's second element, so every
# case is a genuine 2-item batch with a real partial/full-success shape to assert on.

before
  let ns = random string 12

@batch @crud
with each
  | name         | price | category | rowShouldSucceed |
  | "Batch Good" | 12    | "misc"   | true             |
  | "Batch Bad"  | -5    | "misc"   | false            |
test "batch-creates {name} alongside a fixed always-valid filler item" as admin
  api POST /products/batch body {
      items: [
        { name: {name}, price: {price}, category: {category} },
        { name: "Filler Item", price: 1, category: "misc" }
      ]
    }
    header "X-Test-NS" is "{ns}"
  expect status equals 207
  expect body.results[0].ok equals {rowShouldSucceed}
  expect body.results[1].ok equals true
  expect body.succeeded is greater than 0
