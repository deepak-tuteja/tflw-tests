# basic-auth.tflw — M6 (plan_v2.md Part D decision 9): HTTP Basic as a second auth scheme
# alongside bearer/session, applied uniformly through the existing multi-scheme combinator
# (`AnyAuthGuard`) rather than a separate parallel surface. tflw has no `base64(...)` generator
# function (SPEC §5's generator list), so encoding the credential pair forces a JS helper
# (helpers/basic-auth.ts) either way — this test is written to surface that as real evidence for
# TFLW-GAPS.md, not to presuppose whether it's a genuine gap or a working-as-intended punt.

use "./helpers/basic-auth.ts"

@basicauth @identityOps
test "HTTP Basic authenticates the same credentials bearer/session login already accept"
  let basicHeader = basic auth header(env(ADMIN_EMAIL), env(ADMIN_PW))

  api GET /orders/all
    header "Authorization" is "{basicHeader}"
  expect status equals 200

@basicauth @identityOps
test "HTTP Basic with a wrong password is rejected just like a wrong bearer credential"
  let basicHeader = basic auth header(env(ADMIN_EMAIL), "not-the-real-password")

  api GET /orders/all
    header "Authorization" is "{basicHeader}"
  expect status equals 401

@basicauth @authz @identityOps
test "HTTP Basic still respects RBAC — a non-admin Basic credential is forbidden, not waved through"
  let basicHeader = basic auth header(env(USER_A_EMAIL), env(USER_A_PW))

  api GET /orders/all
    header "Authorization" is "{basicHeader}"
  expect status equals 403
