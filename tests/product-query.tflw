# product-query.tflw — plan_v2.md Cluster 4's filter/sort/full-text-search/offset-pagination on
# `GET /products`. Categories are read-only in this API (M2/M3), so the per-test unique facet the
# isolation model calls for (plan_v2.md: "e.g. a unique category") is a unique full-text search
# term embedded in each test's own product names instead — `q=<tag>` scopes every assertion to
# exactly the rows this test created, so exact counts/page math stay parallel-safe under
# `--workers` without a unique category or any test-only header.
#
# Uses an inline admin login (not `as admin`) for the writes, fixed during M13 — the same
# cumulative-suite-timing issue as schema-and-shape.tflw/jobs.tflw (M12/M13): as the suite has
# grown, this file now also sorts late enough for the cached `admin` session's 5s-TTL token to be
# stale here. The `GET /products` reads themselves need no auth at all (public catalog browsing).

use "./helpers/paginate.ts"

before
  api GET /categories
  expect status equals 200
  capture body[0].id as categoryId

  api POST /auth/login body { email: env(ADMIN_EMAIL), password: env(ADMIN_PW) }
  expect status equals 200
  capture body.accessToken as adminToken

@query @crud
test "filtering, sorting, and full-text search combine, scoped to this test's own facet"
  let tag = unique("catalog-tag")
  api POST /products body { name: "{tag} Cheap Item", price: 5, stock: 1, categoryId: {categoryId} }
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 201
  api POST /products body { name: "{tag} Mid Item", price: 15, stock: 1, categoryId: {categoryId} }
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 201
  api POST /products body { name: "{tag} Pricey Item", price: 30, stock: 1, categoryId: {categoryId} }
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 201

  api GET /products?q={tag}&sort=price
  expect status equals 200
  expect body has count 3
  expect body[0].name equals "{tag} Cheap Item"
  expect body[2].name equals "{tag} Pricey Item"

  api GET /products?q={tag}&sort=-price
  expect status equals 200
  expect body[0].name equals "{tag} Pricey Item"

  api GET /products?q={tag}&categoryId={categoryId}
  expect status equals 200
  expect body has count 3

@query @crud
test "sorting by an unrecognized field is a 400, not a silent no-op"
  api GET /products?sort=totallyNotAField
  expect status equals 400

@query @pagination
test "offset pagination reports exact totals for this test's own facet"
  let tag = unique("page-tag")
  api POST /products body { name: "{tag} 1", price: 10, stock: 1, categoryId: {categoryId} }
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 201
  api POST /products body { name: "{tag} 2", price: 10, stock: 1, categoryId: {categoryId} }
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 201
  api POST /products body { name: "{tag} 3", price: 10, stock: 1, categoryId: {categoryId} }
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 201
  api POST /products body { name: "{tag} 4", price: 10, stock: 1, categoryId: {categoryId} }
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 201
  api POST /products body { name: "{tag} 5", price: 10, stock: 1, categoryId: {categoryId} }
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 201

  api GET /products?q={tag}&page=1&pageSize=2
  expect status equals 200
  expect body.page equals 1
  expect body.pageSize equals 2
  expect body.total equals 5
  expect body.totalPages equals 3
  expect body.data has count 2

  api GET /products?q={tag}&page=3&pageSize=2
  expect status equals 200
  expect body.data has count 1

@query @pagination
test "walking every page (via the JS escape hatch) sees every product exactly once"
  let tag = unique("walk-tag")
  api POST /products body { name: "{tag} A", price: 10, stock: 1, categoryId: {categoryId} }
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 201
  api POST /products body { name: "{tag} B", price: 10, stock: 1, categoryId: {categoryId} }
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 201
  api POST /products body { name: "{tag} C", price: 10, stock: 1, categoryId: {categoryId} }
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 201

  let seen = walk all pages(tag, 2)

  api GET /products?q={tag}&page=1&pageSize=50
  expect status equals 200
  expect body.total equals {seen}
