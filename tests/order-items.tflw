# order-items.tflw — the nested `/orders/{id}/items` sub-resource (plan_v2.md Part A), scoped by
# the same ownership rule as its parent order.

before
  api GET /categories
  expect status equals 200
  capture body[0].id as categoryId

  api POST /auth/login body { email: env(ADMIN_EMAIL), password: env(ADMIN_PW) }
  expect status equals 200
  capture body.accessToken as adminToken

  # A dedicated product with its own stock (M15) — the old `GET /products` + `body[0].id` grabbed
  # *whatever* product currently sorted first in the whole catalog.
  api POST /products body { name: unique("Order-items Widget"), price: 10, stock: 10, categoryId: {categoryId} }
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 201
  capture body.id as productId

  api POST /auth/login body { email: env(USER_A_EMAIL), password: env(USER_A_PW) }
  expect status equals 200
  capture body.accessToken as userAToken

  api POST /auth/login body { email: env(USER_B_EMAIL), password: env(USER_B_PW) }
  expect status equals 200
  capture body.accessToken as userBToken

@crud @orderOps
test "reading an order's nested items reflects what was ordered"
  api POST /orders body { items: [{ productId: {productId}, quantity: 4 }] }
    header "Authorization" is "Bearer {userAToken}"
  expect status equals 201
  capture body.id as orderId

  api GET /orders/{orderId}/items
    header "Authorization" is "Bearer {userAToken}"
  expect status equals 200
  expect body has count 1
  expect all body.quantity equals 4

@crud @authz @orderOps
test "a nested items read is scoped exactly like the parent order"
  api POST /orders body { items: [{ productId: {productId}, quantity: 2 }] }
    header "Authorization" is "Bearer {userAToken}"
  expect status equals 201
  capture body.id as orderId

  api GET /orders/{orderId}/items
    header "Authorization" is "Bearer {userBToken}"
  expect status equals 403

@jsonpath @orderOps
test "asserting one specific item's quantity in a multi-item order is a single correlated check"
  api POST /products body { name: unique("Item A"), price: 5, stock: 10, categoryId: {categoryId} }
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 201
  capture body.id as productIdA

  api POST /products body { name: unique("Item B"), price: 5, stock: 10, categoryId: {categoryId} }
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 201
  capture body.id as productIdB

  api POST /orders body { items: [{ productId: {productIdA}, quantity: 2 }, { productId: {productIdB}, quantity: 5 }] }
    header "Authorization" is "Bearer {userAToken}"
  expect status equals 201
  capture body.id as orderId

  api GET /orders/{orderId}/items
    header "Authorization" is "Bearer {userAToken}"
  expect status equals 200

  # These two independent `any`s each pass on their own — but neither one proves productIdA's item
  # specifically is the one with quantity 2 (each could be "satisfied" by the *other* item and
  # still both pass; SPEC §6.3's quantifiers check one field per element, not a correlated pair).
  # Kept here deliberately as the "looks right, isn't" trap — see the real check right below.
  expect any body.productId equals "{productIdA}"
  expect any body.quantity equals 2

  # The actual correlated check, once you know to look for it (TFLW-GAPS.md gap #3's resolution,
  # 2026-07-07): `any`/`all` quantify over whole array elements when the subject path stops AT the
  # array itself, not narrowed to one field — so pairing the quantifier with `matches subset {...}`
  # checks both fields against the *same* element in one statement, no JS helper needed. No new
  # syntax; this composition already shipped alongside gap #2's fix (PLAN.md decision 88) and was
  # simply never tried against a correlated-pair case until now.
  expect any body matches subset { productId: "{productIdA}", quantity: 2 }

@crud @regression @orderOps
test "GET /orders returns the requester's own orders newest-first"
  let shopperEmail = unique email
  api POST /auth/register body { name: "Order List Shopper", email: {shopperEmail}, password: "orderlist-Pass-123" }
  expect status equals 201
  capture body.accessToken as shopperToken

  # A fresh, never-before-seen shopper (not the shared userA/userB) keeps this order-position
  # assertion parallel-safe: nobody else can be creating an order for this exact identity
  # concurrently under `--workers`, unlike userA/userB which many files share.
  api POST /orders body { items: [{ productId: {productId}, quantity: 1 }] }
    header "Authorization" is "Bearer {shopperToken}"
  expect status equals 201
  capture body.id as firstOrderId

  api POST /orders body { items: [{ productId: {productId}, quantity: 1 }] }
    header "Authorization" is "Bearer {shopperToken}"
  expect status equals 201
  capture body.id as secondOrderId

  api GET /orders
    header "Authorization" is "Bearer {shopperToken}"
  expect status equals 200
  expect body has count 2
  expect body[0].id equals "{secondOrderId}"
  expect body[1].id equals "{firstOrderId}"

@crud @orderOps
test "POST /orders with an empty items array is a clean 422"
  api POST /orders body { items: [] }
    header "Authorization" is "Bearer {userAToken}"
  expect status equals 422

@crud @orderOps
test "POST /orders with a zero or negative quantity is a clean 422"
  api POST /orders body { items: [{ productId: {productId}, quantity: 0 }] }
    header "Authorization" is "Bearer {userAToken}"
  expect status equals 422
  expect any body.errors.field equals "items.0.quantity"

  api POST /orders body { items: [{ productId: {productId}, quantity: -3 }] }
    header "Authorization" is "Bearer {userAToken}"
  expect status equals 422

@crud @orderOps
test "POST /orders missing a required item field is a clean 422"
  api POST /orders body { items: [{ productId: {productId} }] }
    header "Authorization" is "Bearer {userAToken}"
  expect status equals 422
  expect any body.errors.field equals "items.0.quantity"

  api POST /orders body { items: [{ quantity: 1 }] }
    header "Authorization" is "Bearer {userAToken}"
  expect status equals 422
  expect any body.errors.field equals "items.0.productId"

@crud @regression @orderOps
test "reusing an Idempotency-Key with a different request body is a conflict, not a silent replay"
  let key = unique("order-idem-key")

  api POST /orders body { items: [{ productId: {productId}, quantity: 1 }] }
    header "Authorization" is "Bearer {userAToken}"
    header "Idempotency-Key" is "{key}"
  expect status equals 201
  capture body.id as originalOrderId

  # Same key, genuinely different body — must not silently return the original order.
  api POST /products body { name: unique("Idem Mismatch Widget"), price: 5, stock: 5, categoryId: {categoryId} }
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 201
  capture body.id as otherProductId

  api POST /orders body { items: [{ productId: {otherProductId}, quantity: 5 }] }
    header "Authorization" is "Bearer {userAToken}"
    header "Idempotency-Key" is "{key}"
  expect status equals 409
  expect body.detail contains "different request body"

  # The same key with the *original* body is still a legitimate replay.
  api POST /orders body { items: [{ productId: {productId}, quantity: 1 }] }
    header "Authorization" is "Bearer {userAToken}"
    header "Idempotency-Key" is "{key}"
  expect status equals 200
  expect body.id equals "{originalOrderId}"
