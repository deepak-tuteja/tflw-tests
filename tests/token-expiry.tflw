# token-expiry.tflw — M5 gap-provoking scenario: a real access-token expiry → refresh chain
# (JWT_ACCESS_TTL=5s, a genuine short TTL, not a mocked clock). `wait until api` can now carry a
# per-step header (TFLW-GAPS.md gap #4, fixed by testFlow decision 95) — see tests/jobs.tflw's
# third test for that proof against a job resource that actually transitions state within the wait
# budget. Kept as a fixed 6s sleep + one-shot recheck here on purpose: this scenario needs to wait
# *past* the TTL to observe the 401 (a condition that only ever becomes true once, unlike a job
# polling toward "completed"), and the default 5s `timeout wait` budget races the same 5s TTL it's
# testing — a fixed sleep stays the right tool for this one, not a workaround for a missing
# feature. Runs for real (~6s), not simulated — same "real timers, not fake" standard as this
# suite's async-job cluster (M4).

use "./helpers/wait-seconds.ts"

@gaps @tokenexpiry
test "an access token genuinely expires at its configured TTL, and refresh recovers"
  api POST /auth/login body { email: env(USER_A_EMAIL), password: env(USER_A_PW) }
  expect status equals 200
  capture body.accessToken as accessToken
  capture body.refreshToken as refreshToken

  api GET /auth/profile
    header "Authorization" is "Bearer {accessToken}"
  expect status equals 200

  let waited = wait seconds(6)

  # Deliberately a one-shot check, not `wait until api` — see the file header: that construct's
  # own wait budget would race this test's TTL rather than outlast it.
  api GET /auth/profile
    header "Authorization" is "Bearer {accessToken}"
  expect status equals 401

  api POST /auth/refresh body { refreshToken: "{refreshToken}" }
  expect status equals 200
  capture body.accessToken as freshToken

  api GET /auth/profile
    header "Authorization" is "Bearer {freshToken}"
  expect status equals 200
