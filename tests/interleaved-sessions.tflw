# interleaved-sessions.tflw — two identities live in one test: an admin bearer identity and a
# shopper cookie identity, alternating calls within a single test. Proves cookie-jar isolation
# holds with two identities active at once.
#
# Now uses `as admin, shopper` directly (tflw decision 96, closes TFLW-GAPS.md gap #7 — a test can
# opt into several independent sessions at once) instead of an inline ad hoc bearer login — both
# identities' setup is handled by session sugar, no manual `POST /auth/login` needed for admin any
# more. One per-step wrinkle remains, and it's an apiV2 fact, not a tflw one: `AnyAuthGuard` checks
# a bearer `Authorization` header before a session cookie
# (apiV2/src/auth/guards/any-auth.guard.ts), and with both sessions' headers merged onto every
# step by default (SPEC §3.3), admin's bearer would silently win on every request, never letting
# the shopper's cookie identity actually authenticate anything. A per-step `header "Authorization"
# is ""` on the shopper-scoped steps clears the bearer for just that one request — an explicit
# per-step header always wins over a session's (SPEC §3.3's config→session→jar→per-step
# precedence chain), so the guard falls through to the cookie. Confirmed empirically via curl
# before trusting it here: the same request with a real bearer *and* a cookie authenticates as the
# bearer's identity; with an *empty* bearer and the same cookie, it authenticates as the cookie's.

before
  api GET /categories
  expect status equals 200
  capture body[0].id as categoryId

@sessions @interleave
test "admin (bearer) and shopper (cookie) alternate within one test" as admin, shopper
  # Cleared bearer -> falls through to shopper's cookie.
  api GET /auth/profile
    header "Authorization" is ""
  expect status equals 200
  expect body.role equals "user"

  # No override here -> admin's merged bearer applies, as normal.
  api POST /products body { name: unique("Interleave Widget"), price: 8, stock: 5, categoryId: {categoryId} }
  expect status equals 201
  capture body.id as productId

  api GET /auth/profile
    header "Authorization" is ""
  expect status equals 200
  expect body.email equals env(USER_A_EMAIL)

  api POST /orders body { items: [ { productId: {productId}, quantity: 1 } ] }
  expect status equals 201
  capture body.id as orderId

  api GET /orders/{orderId}
  expect status equals 200
  expect body.status equals "pending"
