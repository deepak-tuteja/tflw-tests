# actions-and-helpers.tflw ‚Äî a same-run `action`+`import` (shared/catalog.tflw) and the JS
# escape hatch (`use`, helpers/receipt.ts), chained in one flow.
#
# The second test below is illustrative, not a real business scenario (M21): unlike uuid/password/
# base64 (which all had a genuine apiV2 need ‚Äî UUID primary keys, register's password field, the
# existing Basic-auth guard), nothing in this app returns or consumes a hex-encoded value, and url
# encoding of request paths/queries already happens automatically on every interpolated `{var}`
# (tflw decision 62) ‚Äî so there's no organic gap for `hex`/`url` encode/decode to close here. Kept
# only for dogfood coverage of the two forms decision 9/uuid/password/base64 didn't exercise.

import "./shared/catalog.tflw"
use "./helpers/receipt.ts"

before
  api GET /categories
  expect status equals 200
  capture body[0].id as categoryId

  api POST /auth/login body { email: env(ADMIN_EMAIL), password: env(ADMIN_PW) }
  expect status equals 200
  capture body.accessToken as adminToken

@crud @actions
test "action + JS escape hatch: create, receipt, delete"
  let productName = unique("Action Widget")
  let productId = create product(productName, 22.5, 10, categoryId, adminToken)

  let receipt = make receipt(productId, 22.5)

  api DELETE /products/{productId}
    header "Authorization" is "Bearer {adminToken}"
    header "X-Receipt" is "{receipt}"
  expect status equals 204

@crud @actions
test "illustrative: hex/url transforms round-trip through a real request/response (M21)"
  let tag = unique("hex-url")
  let hexed = hex encode("{tag}")
  let unhexed = hex decode(hexed)
  let urled = url encode("{tag} widget")
  let unurled = url decode(urled)
  let productName = "{unhexed} {unurled}"

  api POST /products body { name: {productName}, price: 5, stock: 1, categoryId: {categoryId} }
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 201
  expect body.name equals "{productName}"
  capture body.id as productId

  api DELETE /products/{productId}
    header "Authorization" is "Bearer {adminToken}"
  expect status equals 204
